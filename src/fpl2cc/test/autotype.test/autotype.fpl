
#
#  test if fpl-generated types are even vaguely sane
#


@comment_style c
@default_main
@generate_types

# what to test here?
#  - optional/multiple (maybe want a '?'?)
#  - terminals
#  x subexpressions
#    - complex subexpression?  i.e. more than one non-ejected thing?
#  x ejectedness
#  x unnamed things
#  - multiple ways to get to the same thing

@type_for things std::string
(thing '.'^)+ -> things +{
    std::cout << stringformat("final type is {}\n", thing@type_name());
    std::cout << thing@catmap("Got: {}\n");
    return stringformat("yay, {} things\n", thing@count());
}+



zeta     -> thing;
list+    -> thing;
analogy+ -> thing;

'zzzzzzzzzz' -> zeta;  # (terminal type)

@type_for word std::string
/[A-Za-z]+/ -> word;
word (','^ word)* -> list +{
    return word@join(", ");
}+

word:a ':' word:b -> relation;
relation:ab '::'^ relation:cd -> analogy;


